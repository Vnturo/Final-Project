
# BACKEND ENVIRONMENT VARIABLES
# Instructions: Create a file named '.env' in the ROOT folder 
# (where server.js is located) and paste the following:

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_actual_database_password_here
DB_NAME=unideals_db
DB_PORT=3306

# Your Stripe Secret Key (Used by Node.js/Express)
STRIPE_SECRET=sk_test_your_stripe_secret_key_here


# 2. FRONTEND ENVIRONMENT VARIABLES
# Instructions: Create a file named '.env' inside the 'client' folder 
# (where vite.config.js is located) and paste the following:

# Your Stripe Public Key (Used by React/Vite)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here 